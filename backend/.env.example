# PDF Summarizer - Environment Configuration
# Copy this file to .env and update values for your environment

# ===========================================
# REQUIRED - Must be set for production
# ===========================================

# JWT Secret Key - Generate a secure random string (at least 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secure-jwt-secret-key-change-this

# ===========================================
# OPTIONAL - Defaults provided
# ===========================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (true/false)
DEBUG=true

# Database URL (SQLite default, use PostgreSQL for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/pdfsummarizer
DATABASE_URL=sqlite:///./app.db

# JWT Configuration
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS Origins (comma-separated list)
# For production, set to your actual frontend domain(s)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_API_PER_MINUTE=60

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ===========================================
# EMAIL CONFIGURATION (for password reset)
# ===========================================

# SendGrid API Key (for transactional emails)
# SENDGRID_API_KEY=your-sendgrid-api-key

# Email sender address
# EMAIL_FROM=noreply@yourdomain.com

# Frontend URL (for password reset links)
# FRONTEND_URL=http://localhost:5173